# Credenciais Omie (Acme) — usadas SÓ pelo script de sync server-side, nunca no frontend.
OMIE_APP_KEY=
OMIE_APP_SECRET=
OMIE_BASE_URL=

# --- Supabase (financeiro AG) ---
# Frontend (Vite) — anon é pública por design, protegida por RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only (scripts de schema/migração) — NUNCA expor no frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Login (Google OAuth AG). Fail-closed: o gate fica LIGADO por padrão; só 'false' desliga.
# Dev local sem Supabase Auth: use 'false'. Produção: NÃO defina como false (deixe ligado).
VITE_AUTH_ENABLED=false
